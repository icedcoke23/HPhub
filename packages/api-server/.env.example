# 数据库配置
DATABASE_URL=postgresql://postgres:password@localhost:5432/scratch_platform

# Redis 配置
REDIS_URL=redis://localhost:6379

# JWT 密钥
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 服务器配置
PORT=3001
NODE_ENV=development

# S3/MinIO 配置
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=scratch-platform
S3_REGION=us-east-1

# 资源代理配置
ASSET_PROXY_URL=https://cdn.turbowarp.org

# 云变量服务配置
CLOUD_HOST=localhost:3001

# 日志配置
LOG_LEVEL=info
